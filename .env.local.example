# Copy to .env.local (gitignored) and fill in from the Supabase dashboard:
# Project Settings -> API. Both values are required.
#
# The VITE_ prefix is mandatory — Vite only exposes env vars starting with
# VITE_ to the client bundle. Rename them and the app silently gets undefined.
#
# The anon key is public by design (RLS is what protects the data).
# The service_role key must NEVER appear here or anywhere in this repo.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
